include LICENSE
include README.md
include pyproject.toml

# Exclude non-package trees from sdist
prune converters
prune docs
prune export_docs
prune langchain_agent
prune tests
prune utils
prune view
prune visualization
prune web_agent
prune dluba,api

# Exclude dev-only files
exclude test_pysap2000.py
exclude .gitignore
prune .kiro
prune .pytest_cache
prune __pycache__
