include LICENSE
include README.md
include pyproject.toml

# Exclude non-package trees from sdist
prune converters
prune docs
prune export_docs
prune examples
prune langchain_agent
prune scripts
prune steel_design
prune tests
prune tests_pure
prune utils
prune view
prune visualization
prune web_agent
prune dluba,api

# Exclude dev-only files
exclude test_pysap2000.py
exclude .gitignore
exclude CLAUDE.md
exclude EXPERT_REVIEW.md
exclude IMPROVEMENTS.md
prune .claude
prune .kiro
prune .codex_*
prune .pytest_cache
prune __pycache__
